{
  "name": "@pksep/bot-api",
  "version": "1.0.0",
  "description": "Sep Chat Bot API SDK — Telegram-style bot framework for sep-chat platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "bun run build"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "keywords": [
    "sep-chat",
    "bot-api",
    "chatbot",
    "bot-framework",
    "telegram-style"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/pksep/sep-bot-api"
  },
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
